{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Flash with picotool",
            "type": "shell",
            "command": "picotool",
            "args": [
                "load",
                "-f",
                "${workspaceFolder}/build/hwlt_pico2.elf"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}